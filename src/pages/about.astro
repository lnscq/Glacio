---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";

const sections = [
  {
    title: "Profile",
    icon: "lucide:user-round",
    body: "Use this page for a short introduction, a personal statement, or a concise overview of what visitors can expect from the site.",
  },
  {
    title: "Experience",
    icon: "lucide:briefcase-business",
    body: "This section works well for a timeline, current role, research direction, or a few milestones that give context to your work.",
  },
  {
    title: "Skills",
    icon: "lucide:cpu",
    body: "List the tools, disciplines, or themes that shape your writing and projects, without turning the page into a full resume.",
  },
];

const stack = [
  { name: "Git", icon: "simple-icons:git", color: "oklch(0.7 0.2 30)" },
  { name: "TypeScript", icon: "simple-icons:typescript", color: "oklch(0.7 0.2 250)" },
  { name: "Astro", icon: "simple-icons:astro", color: "oklch(0.75 0.25 290)" },
  { name: "Tailwind CSS", icon: "simple-icons:tailwindcss", color: "oklch(0.76 0.16 220)" },
  { name: "MDX", icon: "simple-icons:mdx", color: "oklch(0.78 0.17 85)" },
  { name: "RSS", icon: "simple-icons:rss", color: "oklch(0.72 0.2 45)" },
];

const updates = [
  {
    date: "Step 1",
    title: "Update configuration",
    desc: "Edit frosti.config.yaml and replace the example title, avatar, email, and social links.",
  },
  {
    date: "Step 2",
    title: "Replace sample content",
    desc: "Swap the example posts and portfolio entries with your own material before publishing.",
  },
  {
    date: "Step 3",
    title: "Review external services",
    desc: "If you need comments or analytics, connect your own service and remove unused placeholders.",
  },
];
---

<BaseLayout title="About">
  <MainCard
    title="About Glacio"
    description="Glacio is a neutral, customizable about page for your own blog or portfolio."
    textOverlay="ABOUT"
    infoIcon="lucide:user"
  >
    <div class="space-y-10">
      <section class="grid gap-8 md:grid-cols-[160px_minmax(0,1fr)] items-center">
        <div class="mx-auto md:mx-0">
          <img
            src="/template-avatar.svg"
            alt="Glacio avatar"
            width="160"
            height="160"
            loading="eager"
            class="w-32 h-32 md:w-40 md:h-40 rounded-3xl border border-base-content/10 bg-base-200 p-2"
          />
        </div>

        <div class="space-y-4 text-center md:text-left">
          <h1 class="text-3xl md:text-4xl font-bold">Glacio</h1>
          <p class="text-lg text-base-content/75">A calm, customizable starting point for personal blogs, notes, and portfolio-style sites.</p>
          <div class="flex flex-wrap gap-3 justify-center md:justify-start">
            <a href="https://github.com/example" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline gap-2">
              <Icon name="lucide:github" class="w-4 h-4" />
              <span>GitHub</span>
            </a>
            <a href="mailto:hello@example.com" class="btn btn-sm btn-outline gap-2">
              <Icon name="lucide:mail" class="w-4 h-4" />
              <span>Email</span>
            </a>
          </div>
        </div>
      </section>

      <section class="grid gap-4">
        {
          sections.map((section) => (
            <article class="rounded-2xl border border-base-content/10 bg-base-200/45 p-5">
              <h2 class="text-xl font-bold mb-2 flex items-center gap-2">
                <Icon name={section.icon} class="w-5 h-5 text-primary" />
                <span>{section.title}</span>
              </h2>
              <p class="text-base-content/78 leading-7 mb-0">{section.body}</p>
            </article>
          ))
        }
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-5 flex items-center gap-2">
          <Icon name="lucide:layers-3" class="w-6 h-6 text-primary" />
          <span>Tech Stack</span>
        </h2>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
          {
            stack.map((tech) => (
              <div class="flex flex-col items-center justify-center p-4 bg-base-200 rounded-lg hover:bg-base-300 transition-colors">
                <div class="text-3xl mb-2" style={`color: ${tech.color}`}>
                  <Icon name={tech.icon} class="w-10 h-10" />
                </div>
                <span class="text-sm font-medium text-center">{tech.name}</span>
              </div>
            ))
          }
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold mb-5 flex items-center gap-2">
          <Icon name="lucide:list-checks" class="w-6 h-6 text-primary" />
          <span>Glacio Checklist</span>
        </h2>

        <div class="rounded-2xl border border-base-content/10 bg-base-200/45 p-5 space-y-5">
          {
            updates.map((item, i) => (
              <div class="flex gap-4">
                <div class="w-10 h-10 shrink-0 rounded-full bg-primary text-primary-content flex items-center justify-center font-bold">
                  {i + 1}
                </div>
                <div>
                  <div class="text-sm text-base-content/60 mb-1">{item.date}</div>
                  <h3 class="text-lg font-semibold">{item.title}</h3>
                  <p class="text-base-content/78 mt-1 mb-0">{item.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </MainCard>
</BaseLayout>
