---
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FriendCard from "@/components/mdx/FriendCard.astro";
import LinkCard from "@/components/mdx/LinkCard.astro";
import Showcase from "@/components/mdx/Showcase.astro";
import Card from "@/components/temple/Card.astro";
import CardGroup from "@/components/temple/CardGroup.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";

const sites = [{ name: "Glacio Demo", url: "https://glacio.pages.dev/" }];
---

<BaseLayout title="Friends">
  <CardGroup cols="1">
    <MainCard
      title="Friends & Resources"
      description="A collection of links to friends, useful resources, and contributors who inspired or shaped Glacio."
      textOverlay="FRIENDS"
      infoIcon="lucide:link"
    >
      <div class="space-y-10">
        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:users" class="w-6 h-6 text-primary" />
            <span>Friends</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="Example Studio"
              avatar="/template-avatar.svg"
              description="A sample friend card for personal sites, blogs, and independent project pages."
              url="https://example.com/studio"
              type="friend"
            />
            <FriendCard
              name="Docs Garden"
              avatar="/template-avatar.svg"
              description="A documentation-style site focused on notes, references, and tidy long-form writing."
              url="https://example.com/docs"
              type="friend"
            />
            <FriendCard
              name="Frontend Notes"
              avatar="/template-avatar.svg"
              description="A compact design and frontend journal with experiments, snippets, and visual studies."
              url="https://example.com/notes"
              type="friend"
            />
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:git-pull-request" class="w-6 h-6 text-primary" />
            <span>Contributors</span>
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <FriendCard
              name="EveSunMaple"
              avatar="https://github.com/EveSunMaple.png"
              description="Original author of Frosti, the project that Glacio learned from and later diverged from."
              url="https://github.com/EveSunMaple"
              type="contributor"
            />
            <FriendCard
              name="Danny's Blog"
              avatar="https://dannyshi.pages.dev/head.jpg"
              description="This is the main contributor to the secondary development of this template"
              url="https://dannyshi.pages.dev"
              type="contributor"
            />
            <FriendCard
              name="Community Contributor"
              avatar="/template-avatar.svg"
              description="A place to credit collaborators, bug reporters, translators, designers, or documentation help."
              url="https://github.com/lnscq/Glacio/"
              type="contributor"
            />
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
            <Icon name="lucide:bookmark" class="w-6 h-6 text-primary" />
            <span>Useful Resources</span>
          </h2>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <LinkCard
              title="Astro Documentation"
              desc="The official Astro documentation, from basic setup to advanced routing, content, and deployment."
              url="https://docs.astro.build"
              icon="simple-icons:astro"
              categories={["Docs", "Learning", "Reference"]}
            />

            <LinkCard
              title="Tailwind CSS Documentation"
              desc="Reference for utility-first styling, responsive design patterns, and theme customization."
              url="https://tailwindcss.com/docs"
              icon="simple-icons:tailwindcss"
              categories={["Docs", "CSS", "Reference"]}
            />

            <LinkCard
              title="daisyUI Components"
              desc="Browse component patterns and theme options used throughout this template."
              url="https://daisyui.com/components/"
              icon="simple-icons:daisyui"
              categories={["Components", "UI", "Reference"]}
            />

            <LinkCard
              title="Frosti Repository"
              desc="The original project that inspired this template before it was substantially rewritten."
              url="https://github.com/EveSunMaple/Frosti"
              icon="ri:github-line"
              categories={["Inspiration", "Template", "Reference"]}
            />
          </div>
        </section>

        <div class="divider my-8">
          <Icon name="lucide:heart" class="w-10 h-10 text-primary" />
        </div>

        <div class="text-center">
          <p class="text-base-content/80 mb-4">
            This page can serve as a blogroll, a credits page, or a curated resource hub for the people and tools behind
            your site.
          </p>
          <a
            href="https://github.com/lnscq/Glacio/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary gap-2"
          >
            <Icon name="lucide:github" class="w-5 h-5" />
            <span>Contribute on GitHub</span>
          </a>
        </div>
      </div>
    </MainCard>

    <Card>
      <div class="p-4 sm:p-6">
        <div class="space-y-10">
          <section>
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-2">
              <h2 class="text-2xl font-bold flex items-center gap-2">
                <Icon name="lucide:layout-template" class="w-6 h-6 text-primary" />
                <span>Sites Using Glacio</span>
              </h2>
              <a
                href="https://github.com/lnscq/Glacio/"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-sm btn-outline btn-primary gap-2"
              >
                <Icon name="lucide:plus-circle" class="w-4 h-4" />
                <span>Add Your Site</span>
              </a>
            </div>
            <p class="text-base-content/70 mb-6">
              Showcase blogs and portfolios built on Glacio here, or turn this block into a small gallery of community
              forks and adaptations.
            </p>
            <div class="flex flex-wrap items-center gap-3">
              {sites.map((site) => <Showcase name={site.name} url={site.url} />)}
            </div>
          </section>
        </div>
      </div>
    </Card>
  </CardGroup>
</BaseLayout>
