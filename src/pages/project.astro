---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";

const projects = [
  {
    name: "Starter Blog",
    summary: "A sample content site for essays, changelogs, and project notes.",
    stack: "Astro / MDX / Tailwind",
    link: "https://example.com/starter-blog",
  },
  {
    name: "Design Notes",
    summary: "A documentation-style microsite for UI writing, references, and experiments.",
    stack: "Astro / Content Collections",
    link: "https://example.com/design-notes",
  },
  {
    name: "Build Journal",
    summary: "A lightweight project log you can use for weekly updates or public development diaries.",
    stack: "Astro / RSS / Sitemap",
    link: "https://example.com/build-journal",
  },
];

const contributionIdeas = [
  "Pin real repositories, case studies, or writing series here.",
  "Replace example links with working URLs before publishing.",
  "If you prefer, this page can become a resume, a changelog, or a now page.",
];
---

<BaseLayout title="Projects">
  <MainCard
    title="Projects"
    description="A neutral project page with placeholder cards and prompts for customization."
    textOverlay="PROJECTS"
    infoIcon="lucide:code-2"
  >
    <section class="py-4">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        <Icon name="lucide:layout-grid" class="w-6 h-6 text-primary" />
        <span>Sample Project Cards</span>
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {
          projects.map((project) => (
            <article class="rounded-2xl border border-base-content/10 bg-base-200/50 p-5 flex flex-col gap-4">
              <div>
                <h3 class="text-xl font-bold">{project.name}</h3>
                <p class="text-base-content/80 mt-2 mb-0 leading-7">{project.summary}</p>
              </div>

              <div class="text-sm text-base-content/60">{project.stack}</div>

              <a href={project.link} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm gap-2 w-fit">
                <Icon name="lucide:external-link" class="w-4 h-4" />
                <span>Example Link</span>
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="py-4">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
        <Icon name="lucide:lightbulb" class="w-6 h-6 text-primary" />
        <span>How To Customize This Page</span>
      </h2>

      <div class="rounded-2xl border border-base-content/10 bg-base-200/50 p-6">
        <ul class="list-disc pl-6 space-y-3 text-base-content/85">
          {contributionIdeas.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  </MainCard>
</BaseLayout>
